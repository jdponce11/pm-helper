# Copy to `.env` in the project root and adjust. Used by docker compose.

# PostgreSQL (db service + DATABASE_URL for backend)
DB_USER=pm_user
DB_PASSWORD=secure_password_here
DB_NAME=pm_database

# Required: JWT signing and cookie-backed sessions (use a long random string in production)
SECRET_KEY=your-secret-key-for-jwt

# Set to 1 only when users access the app over HTTPS (Secure cookies; required for production TLS)
COOKIE_SECURE=0

# Host ports (change if defaults are already in use; no need to edit docker-compose.yml)
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=5001
DB_HOST_PORT=5433

# API
URGENCY_TIMEZONE=UTC

# Local dev: match your Postgres (see project root `.env.example` for Docker Compose DB_* vars)
DATABASE_URL=postgresql://pm_user:secure_password_here@localhost:5432/pm_database
PORT=3000

# Required for JWT auth (same as project root SECRET_KEY in Docker)
SECRET_KEY=your-secret-key-for-jwt

# “Today” for urgent detection (IANA name, e.g. Europe/Madrid or UTC)
URGENCY_TIMEZONE=UTC
